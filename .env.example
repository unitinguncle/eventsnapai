# ═══════════════════════════════════════════════════════════════════════════
# Server
# ═══════════════════════════════════════════════════════════════════════════
PORT=3001
NODE_ENV=production

# ═══════════════════════════════════════════════════════════════════════════
# Admin Auth
# ═══════════════════════════════════════════════════════════════════════════
# Used as both the legacy x-admin-key header value AND as the initial admin
# user's password on first boot (seeded by src/db/seed.js).
# Must be a long random string. Rotate immediately if compromised.
ADMIN_API_KEY=change_this_to_a_long_random_string

# Required in ADDITION to ADMIN_API_KEY to delete an event (double confirmation).
DELETE_API_KEY=change_this_to_another_long_random_string

# ═══════════════════════════════════════════════════════════════════════════
# JWT
# ═══════════════════════════════════════════════════════════════════════════
JWT_SECRET=change_this_to_another_long_random_string
JWT_EXPIRES_IN=6h

# ═══════════════════════════════════════════════════════════════════════════
# PostgreSQL
# ═══════════════════════════════════════════════════════════════════════════
# Connects to CompreFace's Postgres instance (shared database).
POSTGRES_URL=postgresql://postgres:postgres@compreface-postgres-db:5432/frs

# ═══════════════════════════════════════════════════════════════════════════
# RustFS (S3-compatible object storage)
# ═══════════════════════════════════════════════════════════════════════════
# RUSTFS_ENDPOINT    — internal Docker network address (used for uploads, bucket ops)
# RUSTFS_PUBLIC_ENDPOINT — public-facing URL used to generate presigned URLs that
#                          browsers can reach (e.g. https://storage.raidcloud.in)
RUSTFS_ENDPOINT=http://rustfs_local:9000
RUSTFS_PUBLIC_ENDPOINT=https://storage.raidcloud.in
RUSTFS_ACCESS_KEY=your_rustfs_access_key
RUSTFS_SECRET_KEY=your_rustfs_secret_key
RUSTFS_REGION=us-east-1
# Presigned URL expiry in seconds. 21600 = 6 hours.
# Match this to JWT_EXPIRES_IN if you want URLs to expire with the session.
PRESIGNED_URL_EXPIRY=21600

# ═══════════════════════════════════════════════════════════════════════════
# CompreFace (Face Recognition)
# ═══════════════════════════════════════════════════════════════════════════
# COMPREFACE_URL must point to the compreface-api container (not nginx)
# for /api/* face endpoints.
COMPREFACE_URL=http://compreface-api:8080
# Create one Recognition service and one Detection service in the CompreFace UI,
# then paste their API keys below.
COMPREFACE_API_KEY=your_recognition_service_api_key
COMPREFACE_DETECTION_API_KEY=your_detection_service_api_key

# Face match threshold — minimum similarity score to count as "same person".
# PRODUCTION VALUE: 0.991 — tuned through real-event testing and feedback.
# CompreFace scores are NOT linear probabilities. At Indian wedding scale
# (group photos, varied lighting, partial occlusion), 0.991 eliminates
# false positives from co-attendees caught at similar angles.
# DO NOT lower without thorough testing — you will get strangers in results.
# DO NOT raise above 0.999 — you will miss the same person across photos.
# This value is set in Portainer stack env as FACE_SIMILARITY_THRESHOLD.
FACE_SIMILARITY_THRESHOLD=0.991

# ═══════════════════════════════════════════════════════════════════════════
# CORS
# ═══════════════════════════════════════════════════════════════════════════
# Comma-separated list of allowed origins. Include all frontend domains.
# Example: https://delivery.raidcloud.in,https://storage.raidcloud.in
ALLOWED_ORIGINS=https://delivery.raidcloud.in

# ═══════════════════════════════════════════════════════════════════════════
# Upload Limits (tune per server RAM)
# ═══════════════════════════════════════════════════════════════════════════
# Memory budget: (concurrent managers) × (files per batch) × (file size) must
# stay within free RAM after CompreFace stack (~5.5GB used on 16GB server).
#
# 16GB server recommendation (current): 20 files × 20MB × 3 sessions = 1.2GB safe
# 64GB Unraid recommendation (planned): 50 files × 25MB × 10 sessions = 12.5GB safe
UPLOAD_MAX_FILE_SIZE_MB=40
UPLOAD_MAX_FILES_PER_BATCH=20

# ═══════════════════════════════════════════════════════════════════════════
# SMTP Mailer (Google SMTP)
# ═══════════════════════════════════════════════════════════════════════════
# All SMTP config comes exclusively from these env vars — no hardcoded fallbacks.
# For Gmail: use an App Password (not your Google account password).
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password

# ═══════════════════════════════════════════════════════════════════════════
# Mobile App (Android / iOS)
# ═══════════════════════════════════════════════════════════════════════════
# Android App Links — SHA-256 fingerprint of your EAS release signing keystore.
# Obtain after first EAS build: eas credentials --platform android
# Required for QR code scanning to open the native app instead of the browser.
ANDROID_CERT_FINGERPRINT=

# iOS Universal Links — your Apple Developer Team ID (future, for iOS release)
# Found at: https://developer.apple.com/account → Membership
APPLE_TEAM_ID=

# JWT extended for mobile (24h keeps users logged in without constant re-auth)
# Change in Portainer env — no code change needed.
# JWT_EXPIRES_IN=24h
# PRESIGNED_URL_EXPIRY=86400
