{
  "expo": {
    "name": "EventSnapAI",
    "slug": "eventsnapai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "userInterfaceStyle": "dark",
    "scheme": "eventsnapai",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F1E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.raidcloud.eventsnapai",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "EventSnapAI needs your camera to take selfies for photo search and to scan QR codes.",
        "NSPhotoLibraryUsageDescription": "EventSnapAI needs access to your photo library to upload event photos.",
        "NSPhotoLibraryAddUsageDescription": "EventSnapAI saves downloaded photos to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0F1E"
      },
      "package": "com.raidcloud.eventsnapai",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "delivery.raidcloud.in",
              "pathPrefix": "/e/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow EventSnapAI to access your camera for selfie search and QR scanning."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow EventSnapAI to access your photos to upload event memories."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4CAFE3",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://delivery.raidcloud.in",
      "eas": {
        "projectId": "8d74073e-626b-4160-bd35-5ee7703d0f71"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "unitinguncle",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8d74073e-626b-4160-bd35-5ee7703d0f71"
    }
  }
}
